# Salin ke .env (JANGAN di-commit) lalu isi dengan value asli.
# Daftar ini diambil dari grep `os.getenv` di kode backend — backend/.env.example
# yang lama TIDAK sinkron dengan kode (lihat catatan di CLAUDE.md).

# ── App metadata ──────────────────────────────────────────────────────────────
APP_NAME="Hippo Academy — YouTube Analytics API"
APP_VERSION="2.0.0"
DEBUG=False

# ── Gemini (RAG consultant & thumbnail) ───────────────────────────────────────
GEMINI_API_KEY=ganti_dengan_api_key_asli
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.0-flash-lite

# ── YouTube OAuth 2.0 ─────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=ganti_dengan_client_id_asli
YOUTUBE_CLIENT_SECRET=ganti_dengan_client_secret_asli
# Harus public — di belakang Caddy path /api/* (lihat Caddyfile)
YOUTUBE_REDIRECT_URI=https://wrappyt.web.id/api/auth/youtube/callback

# Redirect tujuan setelah OAuth selesai (frontend production, bukan localhost)
FRONTEND_URL=https://wrappyt.web.id

# ── CORS ──────────────────────────────────────────────────────────────────────
# Di balik Caddy, frontend & backend satu origin (path-based) — origin publik
# tetap perlu didaftarkan untuk request lintas-origin (mis. dari domain lain / testing)
CORS_ORIGINS=https://wrappyt.web.id

# ── Path override (opsional — default sudah benar untuk struktur image ini) ──
# MODEL_PATH=./models
# SCALER_PATH=./scalers
# HIPPO_KB_PATH=./data/hippo_kb.md
# DRAFTS_FILE=./data/drafts.json
# DATA_PROCESSED_PATH=../data/processed
