# Application Metadata
APP_NAME="YouTube Prediction API"
APP_VERSION="1.0.0"
DEBUG=True

# Security
# Secret API KEY for backend access
API_KEY="your-super-secret-api-key"

# CORS configuration
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Machine Learning
# Path relative to the backend folder
MODEL_PATH="./models"

# External Services
# If the backend needs to reach YouTube API
YOUTUBE_API_KEY="your-youtube-data-api-v3-key"

# Database Connection (If applicable for history/stats)
DATABASE_URL="postgresql://user:password@localhost:5432/yt_pred_db"
